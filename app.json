{
  "expo": {
    "name": "Mira",
    "slug": "mira-tv",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "miratv",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.kevinarias.miratv",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.kevinarias.miratv",
      "adaptiveIcon": {
        "backgroundColor": "#272727",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": []
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#272727",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 140
          }
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "react-native-video",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13cf7558-787d-4da7-ae39-4c7427230c90"
      }
    },
    "owner": "kevinarce98",
    "updates": {
      "url": "https://u.expo.dev/13cf7558-787d-4da7-ae39-4c7427230c90"
    }
  }
}
